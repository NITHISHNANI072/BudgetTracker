{
  "info": {
    "name": "BudgetTracker API",
    "_postman_id": "budgettracker-ifn636-a2",
    "description": "Complete API test collection for BudgetTracker — IFN636 Assessment 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5001" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@budget.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login User",
          "event": [{ "listen": "test", "script": { "exec": ["pm.collectionVariables.set('token', pm.response.json().token);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@budget.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/expenses",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 150,\n  \"category\": \"Food\",\n  \"date\": \"2025-06-05\",\n  \"description\": \"Grocery shopping\"\n}" }
          }
        },
        {
          "name": "Get All Expenses",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/expenses",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/expenses/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 200,\n  \"category\": \"Food\",\n  \"date\": \"2025-06-05\"\n}" }
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/expenses/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "ERROR - No Token (401)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/expenses"
          }
        },
        {
          "name": "ERROR - Missing Fields (400)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/expenses",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 100\n}" }
          }
        }
      ]
    },
    {
      "name": "Income",
      "item": [
        {
          "name": "Create Income",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/income",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 5000,\n  \"source\": \"Salary\",\n  \"date\": \"2025-06-01\",\n  \"description\": \"Monthly salary\"\n}" }
          }
        },
        {
          "name": "Get All Income",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/income",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Income",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/income/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 5500,\n  \"source\": \"Salary\",\n  \"date\": \"2025-06-01\"\n}" }
          }
        },
        {
          "name": "Delete Income",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/income/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/budgets",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"category\": \"Food\",\n  \"limitAmount\": 500,\n  \"timePeriod\": \"Monthly\",\n  \"startDate\": \"2025-06-01\"\n}" }
          }
        },
        {
          "name": "Get All Budgets",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/budgets",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Budget",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/budgets/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"category\": \"Food\",\n  \"limitAmount\": 600,\n  \"timePeriod\": \"Monthly\",\n  \"startDate\": \"2025-06-01\"\n}" }
          }
        },
        {
          "name": "Delete Budget",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/budgets/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
