# Copy this file to .env and fill in your own values.
# Never commit your actual .env file — it is listed in .gitignore.

# MongoDB connection string (MongoDB Atlas recommended)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/budgettracker?retryWrites=true&w=majority&appName=Cluster0

# Secret key used to sign JWT tokens — use any long random string
JWT_SECRET=replace_with_a_long_random_secret_string

# Port the backend server listens on
PORT=5001
